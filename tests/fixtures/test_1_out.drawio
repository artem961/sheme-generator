        <mxCell id="err_empty" value="Exception: No students data" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;" parent="1" vertex="1">
          <mxGeometry x="378.75" y="487" width="242.5" height="60" as="geometry" />
        </mxCell>
        <mxCell id="loop_node" value="i = 0, n - 1" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;" parent="1" vertex="1">
          <mxGeometry x="316" y="622" width="168" height="60" as="geometry" />
        </mxCell>
        <mxCell id="func_call" value="normalized = apply_curve(grades&lt;sub&gt;i&lt;/sub&gt;)" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;" parent="1" vertex="1">
          <mxGeometry x="245" y="742" width="310" height="60" as="geometry" />
        </mxCell>
        <mxCell id="check_pass" value="normalized &gt;= 50" style="rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="288" y="862" width="224" height="72" as="geometry" />
        </mxCell>
        <mxCell id="update_stats" value="passed_count = passed_count + 1&lt;br&gt;grades&lt;sub&gt;i&lt;/sub&gt; = normalized&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="263.75" y="994" width="272.5" height="90" as="geometry" />
        </mxCell>
        <mxCell id="check_any_passed" value="passed_count &gt; 0" style="rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="288" y="1144" width="224" height="72" as="geometry" />
        </mxCell>
        <mxCell id="out_success" value="grades, passed_count" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;" parent="1" vertex="1">
